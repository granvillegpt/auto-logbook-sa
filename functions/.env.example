# Server-side Google key (Places + Geocoding). Use ONE of these names — same key is fine.
# For Firebase deploy, set GOOGLE_API_KEY (or the alternates) via secrets / environment.
GOOGLE_API_KEY=

# Alternates (read if GOOGLE_API_KEY is unset):
# GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=
# GOOGLE_GEOCODE_API_KEY=
