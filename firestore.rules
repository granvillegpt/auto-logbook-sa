rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read only
    match /storeLocations/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /storeResolution/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Payment tokens — backend only
    match /logbook_tokens/{docId} {
      allow read, write: if false;
    }

    // Manual admin access link records — backend only (mirrors logbook_tokens)
    match /accessTokens/{docId} {
      allow read, write: if false;
    }

    // PayFast logbook payment history — written by Cloud Functions; admin read in dashboard
    match /payfast_payments/{docId} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.admin == "true" ||
        request.auth.token.role == "admin"
      );
      allow write: if false;
    }

    match /reviews_approved/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /pricing/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /coupons/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /practitioner_codes/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /sponsoredTools/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Articles — public read only when published (CMS writes via Cloud Functions Admin SDK)
    match /articles/{slug} {
      allow read: if resource.data.published == true;
      allow write: if false;
    }

    // Default — block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
