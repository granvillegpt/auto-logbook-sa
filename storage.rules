rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /ads/{fileName} {

      allow read: if true;

      allow create: if
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');

      allow update, delete: if false;
    }

    // Article featured images — admin-only writes; public read for site
    match /articles/{slug}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.auth.token.admin == true &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
